# Brain-Game Backend
# Environment variables — copy to .env and fill in

# Database: SQLite (dev) or PostgreSQL (prod)
DATABASE_URL=sqlite+aiosqlite:///./brain_game.db
# DATABASE_URL=postgresql+psycopg2://brain_game:brain_game@localhost:5432/brain_game

# EEG device
EEG_COM_PORT=COM3

# LLM API (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Server
GAME_SERVER_URL=http://127.0.0.1:8000
